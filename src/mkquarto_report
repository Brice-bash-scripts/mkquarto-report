write_manifest() {
	local manifest_rel=".mkquarto/generated_files_manifest.txt"
	local manifest_abs="$PROJECT_DIR/$manifest_rel"

	mkdir -p "$(dirname "$manifest_abs")"
	printf '%s\n' "${GENERATED_PATHS[@]}" | sort -u >"$manifest_abs"
	log_info "Updated manifest: $manifest_rel"
}

check_latex_engine() {
	if command -v xelatex >/dev/null 2>&1; then
		return 0
	fi
	if command -v lualatex >/dev/null 2>&1; then
		return 0
	fi
	if command -v pdflatex >/dev/null 2>&1; then
		return 0
	fi
	return 1
}

run_validation() {
	local status=0

	case "$VALIDATION_MODE" in
		none)
			log_info "Validation skipped (--validation none)."
			return 0
			;;
		fast)
			log_info "Running fast validation: quarto check"
			if ! (cd "$PROJECT_DIR" && quarto check); then
				status=1
			fi
			;;
		full)
			log_info "Running full validation: quarto render report.qmd --to pdf"
			if ! (cd "$PROJECT_DIR" && quarto render report.qmd --to pdf); then
				status=1
			fi
			;;
		*)
			log_error "Unknown validation mode: $VALIDATION_MODE"
			return 2
			;;
	esac

	return "$status"
}

parse_args() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
			-f|--force)
				FORCE=1
				shift
				;;
			--validation)
				if [[ $# -lt 2 ]]; then
					log_error "--validation requires a value: full | fast | none"
					exit 2
				fi
				VALIDATION_MODE="$2"
				shift 2
				;;
			--fast-validate)
				VALIDATION_MODE="fast"
				shift
				;;
			--no-validate)
				VALIDATION_MODE="none"
				shift
				;;
			-h|--help)
				usage
				exit 0
				;;
			--)
				shift
				break
				;;
			-* )
				log_error "Unknown option: $1"
				usage
				exit 2
				;;
			*)
				if [[ -n "$PROJECT_ARG" ]]; then
					log_error "Only one project-name argument is allowed."
					usage
					exit 2
				fi
				PROJECT_ARG="$1"
				shift
				;;
		esac
	done

	if [[ $# -gt 0 ]]; then
		log_error "Unexpected trailing arguments: $*"
		usage
		exit 2
	fi

	if [[ -z "$PROJECT_ARG" ]]; then
		log_error "project-name is required."
		usage
		exit 2
	fi

	case "$VALIDATION_MODE" in
		full|fast|none) ;;
		*)
			log_error "Invalid validation mode: $VALIDATION_MODE (expected: full|fast|none)"
			exit 2
			;;
	esac
}

main() {
	parse_args "$@"

	require_command "quarto" "Quarto is required. Install Quarto and retry."

	SLUG_TITLE="$(slugify "$PROJECT_ARG")"
	if [[ -z "$SLUG_TITLE" ]]; then
		log_error "Could not derive a valid slug from project-name: $PROJECT_ARG"
		exit 2
	fi

	HUMAN_TITLE="$(to_human_title "$PROJECT_ARG")"

	SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
	REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
	TEMPLATE_ROOT="$REPO_ROOT/docs/02_instructions/templates"

	if [[ ! -d "$TEMPLATE_ROOT" ]]; then
		log_error "Template root not found: $TEMPLATE_ROOT"
		exit 1
	fi

	PROJECT_DIR="$PWD/$SLUG_TITLE"
	MANIFEST_ABS="$PROJECT_DIR/.mkquarto/generated_files_manifest.txt"

	declare -gA PREV_MANAGED=()
	if [[ -f "$MANIFEST_ABS" ]]; then
		while IFS= read -r line; do
			[[ -n "$line" ]] && PREV_MANAGED["$line"]=1
		done <"$MANIFEST_ABS"
	fi

	declare -ga GENERATED_PATHS=()

	log_info "Creating scaffold in: $PROJECT_DIR"
	log_info "Title: $HUMAN_TITLE"
	log_info "Slug: $SLUG_TITLE"

	if ! check_latex_engine; then
		log_warn "No LaTeX engine detected (xelatex/lualatex/pdflatex). Full PDF validation may fail."
	fi

	create_directories

	generate_report_qmd
	generate_quarto_yml
	generate_references_bib
	generate_readme

	copy_template_dir "frontmatter" "content/00_frontmatter"
	copy_template_dir "section_1" "content/section_01"
	copy_template_dir "section_2" "content/section_02"
	copy_template_dir "section_3" "content/section_03"
	copy_template_dir "section_4" "content/section_04"
	copy_template_dir "section_5" "content/section_05"
	copy_template_dir "section_6" "content/section_06"
	copy_template_dir "section_7" "content/section_07"
	copy_template_dir "section_8" "content/section_08"
	copy_template_dir "section_9" "content/section_09"
	copy_template_dir "section_10" "content/section_10"

	copy_template_file "section_11/11_0_figures.md" "content/figures/figures.qmd"
	copy_template_file "section_12/12_0_appendices.md" "content/appendices/appendices.qmd"

	write_manifest

	if run_validation; then
		log_info "Scaffold complete. Validation passed."
		exit 0
	fi

	log_error "Scaffold created, but validation failed."
	exit 1
}

main "$@"
