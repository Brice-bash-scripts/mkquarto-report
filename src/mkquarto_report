#!/usr/bin/env bash

# mkquarto_report
#
# Purpose:
#   Scaffold a PDF-first Quarto technical report project from documented templates.
#
# How To Use This Script:
#   1) Run from the directory where you want the project folder created.
#   2) Pass a single project name argument.
#   3) The script slugifies that argument to name the target folder.
#
#   Examples:
#     ./mkquarto_report Real-Estate-Prediction
#     ./mkquarto_report --fast-validate Mortgage-Analytics
#     ./mkquarto_report --force --validation full Customer-Churn-Study
#
# Runtime Requirements:
#   - Quarto must be installed and available on PATH.
#   - A LaTeX engine is required for full PDF validation
#     (xelatex, lualatex, or pdflatex).
#
# Behavior Contract:
#   - Default mode is idempotent: existing files are skipped with warnings.
#   - --force only overwrites files tracked in the manifest:
#       .mkquarto/generated_files_manifest.txt
#   - User-created/untracked files are not overwritten by --force.
#
# Validation Modes:
#   - full (default): renders report.qmd to PDF.
#   - fast: runs 'quarto check' only.
#   - none: skips validation.
#
# Exit Codes:
#   - 0: scaffold created and selected validation passed (or was skipped).
#   - 1: scaffold created but dependency/validation failure occurred.
#   - 2: invalid CLI usage or invalid argument values.

set -euo pipefail

SCRIPT_NAME="$(basename "$0")"

FORCE=0
VALIDATION_MODE="full"
PROJECT_ARG=""

log_info() {
	printf '[INFO] %s\n' "$1"
}

log_warn() {
	printf '[WARN] %s\n' "$1" >&2
}

log_error() {
	printf '[ERROR] %s\n' "$1" >&2
}

usage() {
	cat <<EOF
Usage:
	$SCRIPT_NAME [options] <project-name>

Description:
	Generate a Quarto PDF-first technical report scaffold.

Options:
	-f, --force               Overwrite only previously generated files (tracked by manifest).
	--validation <mode>       Validation mode: full | fast | none (default: full)
	--fast-validate           Shortcut for --validation fast
	--no-validate             Shortcut for --validation none
	-h, --help                Show this help text

Examples:
	$SCRIPT_NAME Real-Estate-Prediction
	$SCRIPT_NAME --fast-validate Mortgage-Analytics
	$SCRIPT_NAME --force --validation full Customer-Churn-Study
EOF
}

slugify() {
	local raw="$1"
	printf '%s' "$raw" \
		| tr '[:upper:]' '[:lower:]' \
		| sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//; s/-+/-/g'
}

to_human_title() {
	local raw="$1"
	printf '%s' "$raw" \
		| sed -E 's/[-_]+/ /g; s/ +/ /g; s/^ //; s/ $//' \
		| awk '{
				for (i=1; i<=NF; i++) {
					$i=toupper(substr($i,1,1)) tolower(substr($i,2));
				}
				print
			}'
}

require_command() {
	local cmd="$1"
	local message="$2"
	if ! command -v "$cmd" >/dev/null 2>&1; then
		log_error "$message"
		exit 1
	fi
}

contains_prev_manifest_path() {
	local rel="$1"
	[[ -n "${PREV_MANAGED[$rel]:-}" ]]
}

write_managed_file() {
	local rel_path="$1"
	local content="$2"
	local abs_path="$PROJECT_DIR/$rel_path"

	GENERATED_PATHS+=("$rel_path")
	mkdir -p "$(dirname "$abs_path")"

	if [[ -f "$abs_path" ]]; then
		if [[ "$FORCE" -eq 1 ]] && contains_prev_manifest_path "$rel_path"; then
			printf '%s\n' "$content" >"$abs_path"
			log_info "Overwrote generated file: $rel_path"
			return
		fi

		log_warn "Skipping existing file: $rel_path"
		return
	fi

	printf '%s\n' "$content" >"$abs_path"
	log_info "Created file: $rel_path"
}

template_to_qmd_content() {
	local template_path="$1"
	local content

	content="$(cat "$template_path")"
	content="${content//'{{title}}'/$HUMAN_TITLE}"
	content="${content//'${title}'/$HUMAN_TITLE}"

	printf '%s' "$content"
}

copy_template_dir() {
	local src_dir="$1"
	local dst_dir="$2"
	local file

	for file in "$TEMPLATE_ROOT/$src_dir"/*.md; do
		[[ -f "$file" ]] || continue
		local base
		base="$(basename "$file" .md)"
		local dst="$dst_dir/$base.qmd"
		local rendered
		rendered="$(template_to_qmd_content "$file")"
		write_managed_file "$dst" "$rendered"
	done
}

copy_template_file() {
	local src_rel="$1"
	local dst_rel="$2"

	local src="$TEMPLATE_ROOT/$src_rel"
	if [[ ! -f "$src" ]]; then
		log_error "Missing template file: $src"
		exit 1
	fi

	local rendered
	rendered="$(template_to_qmd_content "$src")"
	write_managed_file "$dst_rel" "$rendered"
}

create_directories() {
	local dirs=(
		"content/00_frontmatter"
		"content/section_01"
		"content/section_02"
		"content/section_03"
		"content/section_04"
		"content/section_05"
		"content/section_06"
		"content/section_07"
		"content/section_08"
		"content/section_09"
		"content/section_10"
		"content/figures"
		"content/appendices"
		"assets/images"
		"assets/tables"
		"output"
		".mkquarto"
	)

	local d
	for d in "${dirs[@]}"; do
		mkdir -p "$PROJECT_DIR/$d"
	done
}

